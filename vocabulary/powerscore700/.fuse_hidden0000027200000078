.dd{
  display:none;position:fixed;top:0;left:0;
  background:#fff;
  border:1px solid rgba(0,0,0,.08);
  border-radius:14px;
  min-width:224px;
  box-shadow:0 2px 8px rgba(0,0,0,.06),0 12px 36px rgba(0,0,0,.14);
