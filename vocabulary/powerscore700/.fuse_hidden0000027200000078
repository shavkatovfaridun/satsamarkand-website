// STORAGE helpers
// ══════════════════════════════════════════════════════════════
const SK = 'vocabPS700_progress'; // {pageNum: {wordNum: 'known'|'learning'}}



function shuffleArray(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}
function loadProgress() {
  try { return JSON.parse(localStorage.getItem(SK)) || {}; } catch(e) { return {}; }
}
function saveProgress(p) {
  localStorage.setItem(SK, JSON.stringify(p));
}

// ══════════════════════════════════════════════════════════════
// HOME SCREEN
// ══════════════════════════════════════════════════════════════
function renderHome() {
  const prog = loadProgress();
  let totalKnown = 0, totalLearning = 0, completedPages = 0;

  const grid = document.getElementById('page-grid');
  grid.innerHTML = '';

  for (let p = 1; p <= TOTAL_PAGES; p++) {
    const words = VOCAB[String(p)];
    const total = words.length;
    const pageProg = prog[p] || {};
    const known = Object.values(pageProg).filter(v => v === 'known').length;
    const learning = Object.values(pageProg).filter(v => v === 'learning').length;
    const pct = Math.round((known / total) * 100);
    const allDone = known + learning === total && total > 0;
    if (known === total && total > 0) completedPages++;
    totalKnown += known;
    totalLearning += learning;

    const first = words[0].num, last = words[words.length-1].num;
    const card = document.createElement('div');
    card.className = 'pg-card' + (known === total && total > 0 ? ' done' : '');
    card.innerHTML = `
      <div class="pg-card-label">Page ${p}</div>
      <div class="pg-card-range">Words ${first}–${last}</div>
      <div class="pg-card-prog">
        <div class="pg-prog-bar"><div class="pg-prog-fill" style="width:${pct}%"></div></div>
        <div class="pg-prog-txt">${known}/${total}</div>
      </div>`;
    card.onclick = () => startPage(p);
    grid.appendChild(card);
  }

  document.getElementById('gs-known').textContent = totalKnown;
  document.getElementById('gs-learning').textContent = totalLearning;
  document.getElementById('gs-pages').textContent = completedPages;
}

// ══════════════════════════════════════════════════════════════
// FLASHCARD ENGINE
// ══════════════════════════════════════════════════════════════
let currentPage = 1;
let deck = [];       // array of word objects in current queue
let deckIdx = 0;
let reviewMode = false;
let flipped = false;
let sessionKnown = 0;
let sessionLearning = 0;

function startPage(pageNum, onlyLearning) {
  currentPage = pageNum;
  const words = VOCAB[String(pageNum)];
  const prog = loadProgress();
  const pageProg = prog[pageNum] || {};

  if (onlyLearning) {
    deck = shuffleArray(words.filter(w => pageProg[w.num] === 'learning'));
    reviewMode = true;
  } else {
    deck = shuffleArray([...words]);
    reviewMode = false;
    sessionKnown = Object.values(pageProg).filter(v => v === 'known').length;
    sessionLearning = Object.values(pageProg).filter(v => v === 'learning').length;
  }

  deckIdx = 0;
  showScreen('flash');
  document.getElementById('fc-page-label').textContent = 'Page ' + pageNum;
  updateReviewBadge();
  loadCard();
}

function loadCard() {
  if (deckIdx >= deck.length) {
    showCompletion();
    return;
  }
  const w = deck[deckIdx];
  flipped = false;
  document.getElementById('card-3d').classList.remove('flipped');
  document.getElementById('fc-btns').classList.add('hidden');
  resetHint();

  document.getElementById('card-num').textContent = '#' + w.num;
  document.getElementById('card-word').textContent = w.word;
  const hb = document.getElementById('hint-box'); if(hb) hb.textContent = SENTENCES[w.word] || '';
  document.getElementById('card-num-back').textContent = '#' + w.num;
  document.getElementById('card-word-back').textContent = w.word;
  document.getElementById('card-def').textContent = w.def;

  updateProgress();
}

function flipCard() {
  if (flipped) return;
  flipped = true;
  document.getElementById('card-3d').classList.add('flipped');
  setTimeout(() => document.getElementById('fc-btns').classList.remove('hidden'), 300);
}

function markCard(status) {
  const w = deck[deckIdx];
  const prog = loadProgress();
  if (!prog[currentPage]) prog[currentPage] = {};

  const prev = prog[currentPage][w.num];
  prog[currentPage][w.num] = status;
  saveProgress(prog);

  // Update session counts
  if (!reviewMode) {
    if (prev === 'known' && status !== 'known') sessionKnown--;
    if (prev !== 'known' && status === 'known') sessionKnown++;
    if (prev === 'learning' && status !== 'learning') sessionLearning--;
    if (prev !== 'learning' && status === 'learning') sessionLearning++;
  }

  updateReviewBadge();
  deckIdx++;
  loadCard();
}

function updateProgress() {
  const total = deck.length;
  const done = deckIdx;
  const pct = total > 0 ? Math.round((done / total) * 100) : 0;
  document.getElementById('fc-prog-txt').textContent = `${done + 1} / ${total}`;

  const prog = loadProgress();
  const pageProg = prog[currentPage] || {};
  const knownCount = Object.values(pageProg).filter(v => v === 'known').length;
  document.getElementById('fc-known-txt').textContent = knownCount + ' known';
  document.getElementById('fc-prog-fill').style.width = pct + '%';
}

function updateReviewBadge() {
  const prog = loadProgress();
  const pageProg = prog[currentPage] || {};
  const learningCount = Object.values(pageProg).filter(v => v === 'learning').length;
  const badge = document.getElementById('fc-review-badge');
  if (learningCount > 0) {
    badge.style.display = '';
    badge.textContent = learningCount + ' to review';
  } else {
    badge.style.display = 'none';
  }
}

function showCompletion() {
  const prog = loadProgress();
  const pageProg = prog[currentPage] || {};
  const knownCount = Object.values(pageProg).filter(v => v === 'known').length;
  const learningCount = Object.values(pageProg).filter(v => v === 'learning').length;
  const totalWords = VOCAB[String(currentPage)].length;

  document.getElementById('comp-known').textContent = knownCount;
  document.getElementById('comp-learning').textContent = learningCount;

  const allKnown = knownCount === totalWords;
