<style>
:root{
  --navy:#022049;--navy2:#011535;--navy3:#010e24;
  --blue:#0661de;--blue2:#0450b4;--elec:#2979ff;
  --bpale:#e8f0fe;--bxpale:#f0f4ff;
  --t:#1d1d1f;--t2:#3d3d3d;--tm:#6e6e73;--tl:#86868b;
  --bg:#fff;--bg2:#f5f5f7;--bg3:#e8ecf0;
  --bd:#d2d2d7;--bd2:#c0c0c8;
  --ss:0 1px 3px rgba(0,0,0,.06),0 1px 8px rgba(0,0,0,.04);
  --sm:0 2px 12px rgba(0,0,0,.08),0 4px 24px rgba(0,0,0,.05);
  --sl:0 8px 32px rgba(0,0,0,.1),0 2px 8px rgba(0,0,0,.06);
  --r:12px;--rsm:8px;--rlg:18px;--rxl:24px;
  --f:-apple-system,BlinkMacSystemFont,'SF Pro Display','Segoe UI',system-ui,sans-serif;
  --ft:-apple-system,BlinkMacSystemFont,'SF Pro Text','Segoe UI',system-ui,sans-serif;
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;-webkit-font-smoothing:antialiased}
body{font-family:var(--ft);background:var(--bg);color:var(--t);line-height:1.6;overflow-x:hidden}
a{text-decoration:none;color:inherit}

/* LANG BAR */
.lbar{background:var(--navy3);display:flex;justify-content:flex-end;gap:2px;padding:6px 5vw;align-items:center}
.lb{background:none;border:none;color:rgba(255,255,255,.4);font-size:.72rem;font-weight:500;font-family:var(--f);letter-spacing:.04em;padding:4px 10px;border-radius:20px;cursor:pointer;transition:all .15s}
.lb:hover{color:rgba(255,255,255,.75)}
.lb.on{color:#fff;background:rgba(255,255,255,.12)}

/* NAV */
nav{position:sticky;top:0;z-index:2000;background:rgba(255,255,255,.92);backdrop-filter:saturate(180%) blur(20px);-webkit-backdrop-filter:saturate(180%) blur(20px);border-bottom:1px solid rgba(0,0,0,.07)}
.ni{max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding:0 5vw;height:52px}
.nlogo{display:flex;align-items:center;gap:9px;text-decoration:none;flex-shrink:0}
.nlogo img{height:28px;width:28px;object-fit:contain}
.nlt{display:flex;flex-direction:column;line-height:1.15}
.nlt1{font-size:.55rem;font-weight:700;letter-spacing:.2em;color:var(--blue);text-transform:uppercase}
.nlt2{font-size:.75rem;font-weight:700;letter-spacing:.08em;color:var(--navy);text-transform:uppercase}
.nlinks{display:flex;list-style:none}
.nlinks a{color:var(--tm);font-size:.78rem;font-weight:400;padding:0 10px;height:52px;display:flex;align-items:center;transition:color .15s;border-bottom:2px solid transparent;letter-spacing:.005em}
.nlinks a:hover{color:var(--t)}
.nlinks a.on{color:var(--blue);border-bottom-color:var(--blue)}
.nright{display:flex;align-items:center;gap:8px}
.nenroll{background:var(--blue);color:#fff;border:none;padding:8px 18px;border-radius:20px;font-size:.82rem;font-weight:600;font-family:var(--f);cursor:pointer;text-decoration:none;transition:background .15s;white-space:nowrap}
.nenroll:hover{background:var(--blue2)}
.nham{display:none;background:none;border:none;cursor:pointer;padding:6px;color:var(--t)}

/* LAYOUT */
.w{max-width:1200px;margin:0 auto;padding:0 5vw}
.sec{padding:72px 0}
.sec.alt{background:var(--bg2)}
.div{height:1px;background:var(--bd)}
.slbl{font-size:.67rem;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--blue);margin-bottom:.6rem;display:flex;align-items:center;gap:7px}
.slbl::before{content:'';width:12px;height:2px;background:var(--blue);border-radius:1px;flex-shrink:0}
.sh{font-family:var(--f);font-size:clamp(1.75rem,3.5vw,2.75rem);font-weight:700;letter-spacing:-.02em;color:var(--navy);line-height:1.15;margin-bottom:.7rem}
.sh.inv{color:#fff}
.sp{font-size:.95rem;color:var(--tm);line-height:1.7;max-width:540px}
.shd{display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:2.4rem;flex-wrap:wrap;gap:1rem}
.smore{font-size:.83rem;color:var(--blue);font-weight:600;white-space:nowrap}
.smore:hover{text-decoration:underline}

/* BUTTONS */
.btnf{display:inline-flex;align-items:center;gap:6px;background:var(--blue);color:#fff;border:none;padding:13px 26px;border-radius:980px;font-size:.93rem;font-weight:600;font-family:var(--f);cursor:pointer;text-decoration:none;transition:background .15s,transform .1s}
.btnf:hover{background:var(--blue2);transform:scale(.98)}
.btns{display:inline-flex;align-items:center;gap:6px;background:transparent;color:var(--blue);border:1.5px solid var(--blue);padding:12px 24px;border-radius:980px;font-size:.93rem;font-weight:600;font-family:var(--f);cursor:pointer;text-decoration:none;transition:all .15s}
.btns:hover{background:var(--bxpale)}
.btnw{display:inline-flex;align-items:center;gap:6px;background:#fff;color:var(--navy);border:none;padding:13px 26px;border-radius:980px;font-size:.93rem;font-weight:700;font-family:var(--f);cursor:pointer;text-decoration:none;transition:all .15s;white-space:nowrap}
.btnw:hover{background:var(--bg2);transform:scale(.98)}

/* PAGE HERO */
.page-hero{background:var(--navy);padding:64px 5vw;text-align:center;position:relative;overflow:hidden}
.page-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 70% 80% at 50% -20%,rgba(6,97,222,.2),transparent 65%);pointer-events:none}
.page-hero .slbl{justify-content:center;color:rgba(255,255,255,.45)}
.page-hero .slbl::before{background:rgba(255,255,255,.2)}
.page-hero h1{font-family:var(--f);font-size:clamp(2rem,4.5vw,3.5rem);font-weight:700;letter-spacing:-.03em;color:#fff;margin-bottom:.8rem;position:relative}
.page-hero h1 em{font-style:normal;color:#60a5fa}
.page-hero p{font-size:1.05rem;color:rgba(255,255,255,.65);max-width:560px;margin:0 auto;line-height:1.65;position:relative}

/* FOOTER */
.footer{background:var(--navy3);border-top:1px solid rgba(255,255,255,.05);padding:52px 5vw 32px}
.fgrid{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:3rem}
.flogrow{display:flex;align-items:center;gap:8px;margin-bottom:.7rem}
.flogrow img{height:24px;width:24px;object-fit:contain}
.fbrand{font-size:.82rem;font-weight:700;color:#fff;letter-spacing:.04em}
.fbrand span{color:rgba(100,160,255,.82)}
.ftagline{font-size:.78rem;color:rgba(255,255,255,.35);line-height:1.6;max-width:210px}
.fpartner{font-size:.7rem;color:rgba(255,255,255,.2);margin-top:.55rem}
.fcol h4{font-size:.63rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:rgba(255,255,255,.25);margin-bottom:.85rem;padding-bottom:.4rem;border-bottom:1px solid rgba(255,255,255,.05)}
.fcol a,.fcol p{display:block;font-size:.8rem;color:rgba(255,255,255,.45);text-decoration:none;margin-bottom:.4rem;transition:color .15s}
.fcol a:hover{color:rgba(255,255,255,.8)}
.fbot{max-width:1200px;margin:36px auto 0;padding-top:18px;border-top:1px solid rgba(255,255,255,.05);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.5rem}
.fbot p,.fbot a{font-size:.72rem;color:rgba(255,255,255,.2);text-decoration:none}
.fbot a:hover{color:rgba(255,255,255,.5)}










/* CARDS */
.card{background:#fff;border:1px solid var(--bd);border-radius:var(--rlg);padding:28px;box-shadow:var(--ss);transition:box-shadow .2s,transform .2s}
.card:hover{box-shadow:var(--sm);transform:translateY(-2px)}
.tag{display:inline-block;font-size:.65rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:3px 10px;border-radius:20px}
.tag-blue{background:var(--bxpale);color:var(--blue);border:1px solid rgba(6,97,222,.15)}
.tag-green{background:#dbeafe;color:#1d4ed8;border:1px solid #93c5fd}
.tag-gold{background:#fef3c7;color:#92400e;border:1px solid #fcd34d}

/* FADE */
.fade{opacity:0;transform:translateY(14px);transition:opacity .5s ease,transform .5s ease}
.fade.in{opacity:1;transform:translateY(0)}

@media(max-width:960px){.nlinks{display:none}.nham{display:block}.fgrid{grid-template-columns:1fr 1fr}.fgrid>div:first-child{grid-column:1/-1}}
@media(max-width:640px){.fgrid{grid-template-columns:1fr}}

.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:2.5rem;margin-top:2rem}
.contact-info{display:flex;flex-direction:column;gap:14px}
.ci{background:#fff;border:1px solid var(--bd);border-radius:var(--r);padding:22px;display:flex;align-items:flex-start;gap:14px;box-shadow:var(--ss);transition:box-shadow .2s,transform .2s;text-decoration:none;color:inherit}
.ci:hover{box-shadow:var(--sm);transform:translateY(-2px)}
.ci-icon{width:42px;height:42px;border-radius:11px;background:var(--bxpale);border:1px solid rgba(6,97,222,.13);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.ci-icon svg{width:19px;height:19px;stroke:var(--blue);fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round}
.ci h4{font-size:.9rem;font-weight:700;color:var(--navy);margin-bottom:.25rem}
.ci .main-link{font-size:.85rem;color:var(--blue);font-weight:600;display:block;margin-bottom:.2rem}
.ci p{font-size:.78rem;color:var(--tm);line-height:1.5}

.branches-grid{display:grid;grid-template-columns:1fr;gap:14px;margin-top:1.5rem}
.branch{background:#fff;border:1px solid var(--bd);border-radius:var(--r);padding:22px;box-shadow:var(--ss);transition:box-shadow .2s}
.branch:hover{box-shadow:var(--sm)}
.branch.soon{opacity:.65}
.branch-head{display:flex;align-items:center;gap:14px;margin-bottom:.8rem}
.branch-n{font-family:var(--f);font-size:1.7rem;font-weight:700;color:var(--bg3);line-height:1;letter-spacing:-.04em;flex-shrink:0}
.branch.active .branch-n{color:var(--blue);background:linear-gradient(135deg,var(--blue),var(--elec));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.branch-status{display:inline-flex;align-items:center;gap:5px;font-size:.66rem;font-weight:700;padding:3px 10px;border-radius:20px;letter-spacing:.05em;text-transform:uppercase}
.branch.active .branch-status{background:#dbeafe;color:#1d4ed8;border:1px solid #93c5fd}
.branch.soon .branch-status{background:var(--bg2);color:var(--tl);border:1px solid var(--bd)}
.branch-dot{width:6px;height:6px;border-radius:50%}
.branch.active .branch-dot{background:#0661de}
.branch.soon .branch-dot{background:var(--tl)}
.branch h4{font-size:.95rem;font-weight:700;color:var(--navy);margin-bottom:.3rem;letter-spacing:-.01em}
.branch-addr{font-size:.83rem;color:var(--tm);margin-bottom:1rem;display:flex;align-items:center;gap:6px}
.branch-addr svg{width:14px;height:14px;stroke:var(--tm);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0}
.branch a.b-btn{display:inline-flex;align-items:center;gap:6px;font-size:.78rem;color:var(--blue);font-weight:600;text-decoration:none;border:1.5px solid rgba(6,97,222,.22);padding:7px 14px;border-radius:980px;background:var(--bxpale);transition:all .15s}
.branch a.b-btn:hover{border-color:var(--blue);background:var(--bpale)}
.branch.soon span.b-btn{display:inline-flex;align-items:center;gap:6px;font-size:.78rem;color:var(--tl);font-weight:600;border:1.5px solid var(--bd);padding:7px 14px;border-radius:980px;background:var(--bg2)}

.action-card{background:linear-gradient(135deg,var(--bxpale),#fff);border:1.5px solid rgba(6,97,222,.18);border-radius:var(--rlg);padding:24px;margin-top:1.5rem}
.action-card h4{font-size:.95rem;font-weight:700;color:var(--navy);margin-bottom:.5rem}
.action-card p{font-size:.83rem;color:var(--tm);margin-bottom:1.1rem;line-height:1.55}
@media(max-width:760px){.contact-grid{grid-template-columns:1fr;gap:1.8rem}}

/* ═══ BREADCRUMBS ═══ */
.breadcrumb-nav{background:rgba(2,32,73,.04);border-bottom:1px solid rgba(2,32,73,.08);padding:0}
.breadcrumb-inner{max-width:1200px;margin:0 auto;padding:10px 5vw}
.breadcrumb-list{list-style:none;display:flex;align-items:center;gap:6px;flex-wrap:wrap}
.breadcrumb-list a{font-size:.78rem;color:var(--blue);text-decoration:none;font-weight:500}
.breadcrumb-list a:hover{text-decoration:underline}
.breadcrumb-list li:last-child{font-size:.78rem;color:var(--tm)}
.bc-sep{color:var(--tl);font-size:.78rem}


@media(max-width:960px){
  .nlinks.open{display:flex!important;flex-direction:column;position:fixed;top:52px;left:0;right:0;background:#fff;box-shadow:0 8px 32px rgba(0,0,0,.14);z-index:499;padding:6px 0;max-height:calc(100vh - 52px);overflow-y:auto}
  .nlinks.open li{display:block;width:100%}
  .nlinks.open a{height:48px;padding:0 24px;border-bottom:1px solid var(--bg2)!important;color:var(--t)!important;font-size:.92rem;width:100%}
