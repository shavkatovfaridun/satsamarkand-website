<script>
const LANGS = ['en','uz','ru'];
let currentLang = localStorage.getItem('sats_lang') || 'en';

function applyLang(lang) {
  document.querySelectorAll('[data-' + lang + ']').forEach(el => {
    const v = el.getAttribute('data-' + lang);
    if (v !== null) {
      // For inputs/textareas with placeholder, set placeholder if data-placeholder exists
      if (el.hasAttribute('data-' + lang + '-placeholder')) {
        el.placeholder = el.getAttribute('data-' + lang + '-placeholder');
      } else {
        el.innerHTML = v;
      }
    }
  });
  // Handle placeholder data attributes (data-en-ph, data-uz-ph, data-ru-ph)
  document.querySelectorAll('[data-' + lang + '-ph]').forEach(el => {
    el.placeholder = el.getAttribute('data-' + lang + '-ph');
  });
  document.documentElement.lang = lang;
  document.querySelectorAll('.lb').forEach(b => {
    b.classList.toggle('on', b.dataset.lang === lang);
  });
}

function setLang(lang) {
  currentLang = lang;
  localStorage.setItem('sats_lang', lang);
  applyLang(lang);
}

document.addEventListener('DOMContentLoaded', () => applyLang(currentLang));

function toggleNav() {
  const nl = document.getElementById('nlinks');
  if (!nl) return;
  if (nl.classList.contains('mo')) {
    nl.classList.remove('mo');
    nl.style.cssText = '';
  } else {
    nl.classList.add('mo');
    nl.style.cssText = 'display:flex;flex-direction:column;position:fixed;top:52px;left:0;right:0;background:rgba(255,255,255,.97);backdrop-filter:blur(20px);padding:12px 5vw 20px;gap:4px;z-index:499;border-bottom:1px solid var(--bd);box-shadow:var(--sm)';
    nl.querySelectorAll('a').forEach(a => {
      a.style.cssText = 'height:44px;padding:0;border-bottom:1px solid var(--bg2);font-size:.95rem';
    });
  }
}

const obs = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('in'); });
}, { threshold: 0.06 });
document.querySelectorAll('.fade').forEach((el, i) => {
  el.style.transitionDelay = (i % 5) * 0.07 + 's';
  obs.observe(el);
});

window.addEventListener('scroll', () => {
  const fb = document.getElementById('fb');
  if (!fb) return;
  const footer = document.querySelector('.footer');
  if (footer && window.scrollY + window.innerHeight >= footer.offsetTop) {
    fb.style.opacity = '0';
    fb.style.pointerEvents = 'none';
  } else {
    fb.style.opacity = '1';
    fb.style.pointerEvents = 'auto';
  }
}, { passive: true });
</script>

