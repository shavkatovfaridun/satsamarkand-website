.mob-nav .mob-list{list-style:none;padding:6px 0 12px;margin:0}
.mob-nav .mob-list>li>a{display:block;padding:13px 20px;color:var(--t,#1d1d1f);
  font-size:.95rem;text-decoration:none;border-bottom:1px solid #f5f5f7}
.mob-nav .mob-list>li>a:hover{background:var(--bxpale,#f0f4ff);color:var(--blue,#0661de)}
.mob-group-hd{display:flex;align-items:center;justify-content:space-between;
