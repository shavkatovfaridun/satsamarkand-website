function toggleHint(e) {
  e.stopPropagation();
  const box = document.getElementById('hint-box');
  const btn = document.getElementById('hint-btn');
  const visible = box.classList.toggle('visible');
  btn.textContent = visible ? 'Hide Example' : 'Show Example';
}

function resetHint() {
  const box = document.getElementById('hint-box');
  const btn = document.getElementById('hint-btn');
  if (box) { box.classList.remove('visible'); box.textContent = ''; }
  if (btn) btn.textContent = 'Show Example';
}

