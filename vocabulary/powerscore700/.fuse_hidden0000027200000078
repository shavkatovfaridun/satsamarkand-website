.mob-group-body li a:hover{background:var(--bxpale,#f0f4ff);color:var(--blue,#0661de)}
.mob-nav .mob-enroll{display:block;margin:12px 20px 8px;padding:14px 24px;
  background:var(--blue,#0661de);color:#fff!important;border-radius:10px;
  text-align:center;font-weight:600;font-size:.95rem;border-bottom:none!important;
  text-decoration:none}
.mob-nav .mob-enroll:hover{background:#0550c0!important;color:#fff!important}
/* Hamburger → X animation */
