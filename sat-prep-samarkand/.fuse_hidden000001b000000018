  var group = btn.closest('.mob-group');
  var isOpen = group.classList.contains('open');
  document.querySelectorAll('.mob-group.open').forEach(function(g){ g.classList.remove('open'); });
  if (!isOpen) group.classList.add('open');
}
document.addEventListener('click', function(e) {
  var mn = document.getElementById('mobnav');
  if (mn && mn.classList.contains('open')) {
    if (!e.target.closest('.mob-nav') && !e.target.closest('.nham')) {
      mn.classList.remove('open');
      var btn = document.querySelector('.nham');
      if (btn) btn.classList.remove('open');
