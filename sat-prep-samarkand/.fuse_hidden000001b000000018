<script>
// ═══ LANGUAGE ═══
let currentLang = localStorage.getItem('sats_lang');
if (!currentLang) {
  const bl = (navigator.language || 'en').toLowerCase();
  currentLang = bl.startsWith('uz') ? 'uz' : bl.startsWith('ru') ? 'ru' : 'en';
}

function applyLang(lang) {
  document.querySelectorAll('[data-' + lang + ']').forEach(el => {
    const v = el.getAttribute('data-' + lang);
    if (v !== null) el.innerHTML = v;
  });
  document.documentElement.lang = lang;
  document.querySelectorAll('.lb').forEach(b => b.classList.toggle('on', b.dataset.lang === lang));
}

function setLang(lang) {
  currentLang = lang;
  localStorage.setItem('sats_lang', lang);
  applyLang(lang);
}

document.addEventListener('DOMContentLoaded', () => applyLang(currentLang));

// ═══ NAV SCROLL ═══
window.addEventListener('scroll', () => {
  const nav = document.querySelector('nav');
  if (nav) nav.classList.toggle('scrolled', window.scrollY > 10);
});

// ═══ EXIT POPUP ═══
function closeExitPopup() {
  const p = document.getElementById('exitPopup');
  if (p) p.classList.remove('active');
}
let exitShown = false;
document.addEventListener('mouseleave', (e) => {
  if (e.clientY < 10 && !exitShown) {
    exitShown = true;
    const p = document.getElementById('exitPopup');
    if (p) p.classList.add('active');
  }
});

