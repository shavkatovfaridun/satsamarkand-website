  var mn = document.getElementById('mobnav');
  var btn = document.querySelector('.nham');
  if (mn) { mn.classList.toggle('open'); if (btn) btn.classList.toggle('open'); }
  else { var nl = document.getElementById('nlinks'); if (nl) nl.classList.toggle('open'); }
